TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO

# OpenAI-compatible Chat Completions (e.g. OpenRouter). Also accepts OPENROUTER_* names.
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=
# Optional second model if the first fails (rate limits, etc.)
LLM_MODEL_FALLBACK=
LLM_HTTP_REFERER=https://github.com/
LLM_APP_TITLE=Sous-chef
LLM_MAX_REQUESTS_PER_USER_PER_HOUR=20
